# Emit — Environment Variables
# Copy this file to .env and fill in the values you need.
# Only the variables relevant to your setup are required.

# ── LLM Provider (pick one) ───────────────────────────────
# Not needed if using Claude Code CLI as your provider.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Snowflake (optional — for warehouse-powered event discovery) ──
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USERNAME=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# ── Segment (optional — for tracking plan import or push) ──
SEGMENT_API_TOKEN=
