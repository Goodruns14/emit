{
  "name": "emit-catalog",
  "version": "0.2.0",
  "description": "Automatic event catalog generator — extract semantic metadata from instrumentation code",
  "keywords": [
    "analytics",
    "events",
    "catalog",
    "segment",
    "snowflake",
    "cli"
  ],
  "license": "MIT",
  "author": "Goodruns14",
  "homepage": "https://github.com/Goodruns14/emit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Goodruns14/emit.git"
  },
  "bugs": {
    "url": "https://github.com/Goodruns14/emit/issues"
  },
  "bin": {
    "emit": "dist/cli.js"
  },
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/cli.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@databricks/sql": "^1.13.0",
    "@google-cloud/bigquery": "^8.1.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "cosmiconfig": "^9.0.0",
    "execa": "^8.0.1",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.1",
    "snowflake-sdk": "^1.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/snowflake-sdk": "^1.6.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
